# Mindverse Phase 0 · 环境变量模板
# 复制为 .env 后填入真实凭证。.env 永远不入库。

# ============ LLM（OpenAI 兼容协议） ============
# 兼容：OpenAI / Anthropic / DeepSeek / Zhipu GLM / Qwen / Moonshot / Ollama / vLLM / llama.cpp
LLM_BASE_URL=https://open.bigmodel.cn/api/coding/paas/v4
LLM_API_KEY=
LLM_MODEL=GLM-4.7
LLM_TEMPERATURE=0.7

# ============ Embedding（向量语义检索） ============
# Qwen3-Embedding-0.6B，经独立 llama.cpp embedding server（OpenAI 兼容 /v1/embeddings）。
# compose 已给默认值（embed 服务）；本地裸跑 / 自定义 server 时在此覆盖。
# 留空 = 不启嵌入：写入侧向量留空、query_memory 回退关键词召回，生命体照常运行（优雅降级）。
MINDVERSE_EMBED_URL=http://embed:11435
MINDVERSE_EMBED_MODEL=qwen3-embedding-0.6b

# ============ 飞书（lark-oapi LongConnection） ============
# open.feishu.cn 上创建"企业自建应用"，长连接模式
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# ============ 访问令牌（写操作鉴权） ============
# 把面板暴露到公网时务必设置：观察面板的读操作始终开放，但注入对话 / 改 dangerous-skip /
# 批准装依赖等"写/交互"操作需在面板填入与此一致的令牌。留空 = 不鉴权（仅适合本机访问）。
# 自定义任意一串随机字符串即可，如 openssl rand -hex 16。
MINDVERSE_ACCESS_TOKEN=

# ============ 编码桥（C7 codingbridge，可选） ============
# 让生命在慎思中把编码任务委派给宿主上的强力编码 agent（claude / codex）。
# 桥二进制 taixu-coding-bridge（cmd/codingbridge，从 GitHub Releases 下载）跑在**宿主机**上；
# 本端经 host.docker.internal 指向它，token 双端一致。
# 也可在面板「编码桥」区配置（即时生效）。留空 = coding_agent 工具缺席（优雅降级）。详见 README。
TAIXU_CODINGBRIDGE_URL=
TAIXU_CODINGBRIDGE_TOKEN=
TAIXU_CODINGBRIDGE_AGENT=claude
