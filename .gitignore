# 凭证 / 配置（绝不入库）
.env
.env.local
.env.*.local
*.key
*.pem
*-secrets.yaml

# 本地数据（生命体加密包 / SQLite / 沙箱 / 工作目录运行产物）
data/
sandbox/
workspace/sandbox/
# skill 装的依赖（运行时生成，不入库）；保留 skill 文件夹本身 + SKILL.md + 脚本
workspace/skills/*/site-packages/
workspace/skills/*/node_modules/
*.db
*.db-journal
*.db-wal
*.db-shm
*.age
lifeform-*.age

# Go 编译产物
/bin/
/dist/
*.exe
*.test
*.out
coverage.txt

# 模型权重（按需下载，不入库）
assets/models/
*.gguf
*.bin
*.safetensors

# 前端（web/.gitignore 補充）
web/node_modules/
web/.svelte-kit/
web/build/
web/.env
web/.vercel/
web/dist/

# Go embed 構建產物（CI / Docker 構建自動生成）
cmd/runtime/webbuild/*
!cmd/runtime/webbuild/.gitkeep

# Node / pnpm
node_modules/
.pnpm-store/
npm-debug.log*
pnpm-debug.log*

# IDE / 工具状态
.vscode/
.idea/
.claude/
*.swp
*.swo
.DS_Store
Thumbs.db

# 临时
*.tmp
*.log
*.bak
__pycache__/
.pytest_cache/

# Docker
.docker-cache/
workspace/skills/python-decorators/
